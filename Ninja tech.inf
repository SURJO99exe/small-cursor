By Tech World
[Version]
signature="$CHICAGO$"

[DefaultInstall]
CopyFiles = Scheme.Cur, Scheme.Txt
AddReg    = Scheme.Reg

[DestinationDirs]
Scheme.Cur = 10,"%CUR_DIR%"
Scheme.Txt = 10,"%CUR_DIR%"

[Scheme.Reg]
HKCU,"Control Panel\Cursors\Schemes","%SCHEME_NAME%",,"%10%\%CUR_DIR%\%pointer%,%10%\%CUR_DIR%\%help%,%10%\%CUR_DIR%\%work%,%10%\%CUR_DIR%\%busy%,%10%\%CUR_DIR%\%Cross%,%10%\%CUR_DIR%\%Text%,%10%\%CUR_DIR%\%Hand%,%10%\%CUR_DIR%\%Unavailiable%,%10%\%CUR_DIR%\%Vert%,%10%\%CUR_DIR%\%Horz%,%10%\%CUR_DIR%\%Dgn1%,%10%\%CUR_DIR%\%Dgn2%,%10%\%CUR_DIR%\%move%,%10%\%CUR_DIR%\%alternate%,%10%\%CUR_DIR%\%link%"

; -- Common Information

[Scheme.Cur]
"aero_arrow.cur"
"aero_helpsel.cur"
"aero_working.ani"
"aero_busy.ani"
"cross_r.cur"
"beam_r.cur"
"aero_pen.cur"
"aero_unavail.cur"
"aero_ns.cur"
"aero_ew.cur"
"aero_nwse.cur"
"aero_nesw.cur"
"aero_move.cur"
"aero_up.cur"
"aero_link.cur"

[Strings]
CUR_DIR		= "Tech World_Small"
SCHEME_NAME	= "Tech World_Small"
pointer		= "aero_arrow.cur"
help		= "aero_helpsel.cur"
work		= "aero_working.ani"
busy		= "aero_busy.ani"
cross		= "cross_r.cur"
text		= "beam_r.cur"
hand		= "aero_pen.cur"
unavailiable	= "aero_unavail.cur"
vert		= "aero_ns.cur"
horz		= "aero_ew.cur"
dgn1		= "aero_nwse.cur"
dgn2		= "aero_nesw.cur"
move		= "aero_move.cur"
alternate	                     = "aero_up.cur"
link		= "aero_link.cur"

